# ============================================
# EDI_MP 環境変数設定ファイル（テンプレート）
# ============================================
# このファイルをコピーして .env.nas を作成してください
#   cp .env.nas.sample .env.nas
#
# 各値を自社の情報に書き換えてください

# --- Django 基本設定 ---
DJANGO_SETTINGS_MODULE=EDI_MP.settings.production
SECRET_KEY=changeme_ランダムな50文字以上の文字列をここに入力
ALLOWED_HOSTS=localhost,127.0.0.1,あなたのNASのIPアドレス
CSRF_TRUSTED_ORIGINS=http://あなたのNASのIPアドレス:8090

# --- メール設定（Gmail例） ---
DEFAULT_FROM_EMAIL=あなたの会社のメールアドレス
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=Gmailアドレス
EMAIL_HOST_PASSWORD=Gmailアプリパスワード

# --- Google Drive連携（任意） ---
# 不要な場合は空欄のままでOK
GOOGLE_DRIVE_SERVICE_ACCOUNT=
GOOGLE_DRIVE_CREDENTIALS_FILE=
